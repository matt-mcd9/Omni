<Window x:Class="Omni.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Omni"
        Height="760" Width="1300"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- custom title bar -->
                <RowDefinition Height="*"/>
                <!-- body -->
            </Grid.RowDefinitions>

            <!-- ===== Title bar ===== -->
            <Grid Grid.Row="0" Background="{StaticResource BgBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="OMNI" Foreground="{StaticResource TextBrush}"
                           FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionButtonStyle}" Click="Minimize_Click"/>
                    <Button Content="&#xE922;" Style="{StaticResource CaptionButtonStyle}" Click="Maximize_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CaptionButtonStyle}" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===== Body: sidebar + page host ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,12,0,0">
                        <RadioButton x:Name="NavHome" Content="Home" Tag="&#x1F3E0;"
                                     Style="{StaticResource NavButtonStyle}"
                                     IsChecked="True" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavMusic" Content="Music" Tag="&#x1F3B5;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavVideos" Content="Videos" Tag="&#x1F3AC;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavGames" Content="Games" Tag="&#x1F3AE;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavSoftware" Content="Software" Tag="&#x1F4E6;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavPlaylists" Content="Playlists" Tag="&#x1F4CB;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavSettings" Content="Settings" Tag="&#x2699;"
                                     Style="{StaticResource NavButtonStyle}" Checked="Nav_Checked"/>
                    </StackPanel>
                </Border>

                <!-- Page host: content is swapped here when a sidebar item is selected -->
                <ContentControl x:Name="PageHost" Grid.Column="1" Margin="24"/>

            </Grid>
        </Grid>
    </Border>
</Window>
