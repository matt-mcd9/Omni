<UserControl x:Class="Omni.Pages.SoftwarePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Software" Foreground="{StaticResource TextBrush}"
                   FontSize="26" FontWeight="Bold"/>

        <Button Width="100"
                Height="50"
                HorizontalAlignment="Left"
                Click="selectFolder_Click"
            >Select Folder</Button>

        <ListBox Background="Black"
                 Foreground="White"
                 MouseDoubleClick="launchApp_MouseDoubleClick"
                 x:Name="listApplications"
                 Width="400"
                 Height="300"/>

    </StackPanel>
</UserControl>
